{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "erasableSyntaxOnly": false,
    "verbatimModuleSyntax": false,
    "types": ["node", "bun"],
    "lib": ["ESNext", "esnext.disposable"]
